# Copy to .env and fill in values.

# Active network: true = Spot Testnet, false = Mainnet
BINANCE_TESTNET=true

# Testnet and mainnet use DIFFERENT, non-interchangeable keys — keep both pairs here
# and switch networks with BINANCE_TESTNET above (no need to re-paste keys).
# Spot Testnet keys: https://testnet.binance.vision
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
# Mainnet keys: https://www.binance.com (API Management)
BINANCE_MAINNET_API_KEY=
BINANCE_MAINNET_API_SECRET=

# (Legacy single-pair vars are still honored as a fallback if the pairs above are empty)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

LOG_LEVEL=INFO
DB_URL=sqlite:///db/trades.db

# ── Backend / API surface ──────────────────────────────────────
# The API exposes trading controls and financial data. It binds to localhost by
# default. To reach it from another machine set API_HOST=0.0.0.0 AND set API_KEY,
# otherwise remote clients can reach sensitive data and controls.
API_HOST=127.0.0.1
API_PORT=8000
# When set, every API route except GET /api/health requires
# header X-API-Key: <this value>.
API_KEY=
# Optional browser/service origins allowed to call the backend API.
# CORS_ORIGINS=https://ops.example.com

# ── Live trading arm switch ────────────────────────────────────
# LIVE LOOPn_MODE values place real orders only when this explicit switch is set.
# Keep false for PAPER/backtest and for test configuration edits.
LIVE_TRADING_ENABLED=false

# ── Strategy Mode ──────────────────────────────────────────────
# rule_based : RsiMacdStrategy only — zero API cost (default)
# hybrid     : RsiMacd pre-filters, Claude validates non-HOLD — ~90% cost reduction
# claude_ai  : Claude on every candle — maximum AI involvement
# multi      : RsiMacd + Bollinger + EMA with regime-aware auto-switching
STRATEGY_MODE=rule_based

# multi-mode tuning:
DEFAULT_STRATEGY=ema_cross       # which technique to start active in multi mode
SWAP_MARGIN=0.10                 # min win-rate edge to switch technique (10pp)
MIN_REGIME_SAMPLES=20            # min trades in a regime before its profile is trusted
SWAP_COOLDOWN_DAYS=1             # at most one technique switch per day
STRATEGY_EPSILON=0.10            # exploration probability when scores are comparable
ARBITER_MODE=rule               # multi-mode arbiter: rule (free) | claude (tool-use agent)
CLAUDE_ARBITER_MODEL=claude-opus-4-8  # used only when ARBITER_MODE=claude

# Required only for hybrid or claude_ai mode
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude model for trading decisions (haiku = cheapest, sonnet = smarter)
# claude-haiku-4-5-20251001  ~$0.006/trade   (recommended for production)
# claude-sonnet-4-6           ~$0.040/trade   (for research)
CLAUDE_STRATEGY_MODEL=claude-haiku-4-5-20251001
# hybrid validate() is the last gate before a real order + runs infrequently → stronger model
CLAUDE_VALIDATE_MODEL=claude-opus-4-8

# ─────────────────────────────────────────────────────────────────────────────
# Multi-loop mode (plan B/C): run several strategies CONCURRENTLY on one account.
# Define LOOP1_*, LOOP2_*, ... — each block is one independent loop with its own
# strategy, timeframe and param overrides. Per-loop keys win over the global keys
# above, which win over code defaults. Leave these unset to run the single legacy
# loop (STRATEGY_MODE). Positions are attributed per strategy via clientOrderId,
# so two strategies can safely hold the same spot symbol at once.
# Go-live guard: mixed LIVE/PAPER scheduled loops are blocked until per-loop
# exchange isolation is implemented. BACKTEST loops are not scheduled by main.py.
#
# Example — ema_cross on 1h + rsi_macd on 4h, both on BTC, one account:
# LOOP1_STRATEGY=ema_cross
# LOOP1_TIMEFRAME=1h
# LOOP1_MODE=LIVE                 # unset falls back to PAPER_TRADING
# LOOP1_ALLOCATION_PCT=0.40       # fractions; all loops should sum to <= 1.0
# LOOP1_ATR_SL_MULT=3.0          # ema_cross 1h best-fit (wr 80%, +420 in backtest)
# LOOP1_ATR_TP_MULT=3.0
#
# LOOP2_STRATEGY=rsi_macd
# LOOP2_TIMEFRAME=4h
# LOOP2_MODE=PAPER
# LOOP2_ALLOCATION_PCT=0.60
# LOOP2_RSI_OVERSOLD=35          # rsi_macd's home is 4h mean-reversion (wr 57%, +67)
# LOOP2_RSI_OVERBOUGHT=65
# LOOP2_RSI_MACD_LONG_ONLY=false
# LOOP2_RSI_MACD_TREND_EMA=0     # 0 = disable the EMA trend filter
# LOOP2_ATR_SL_MULT=2.0
# LOOP2_ATR_TP_MULT=3.0

MAX_POSITION_PCT=0.25            # 25%/trade — spot has no liquidation (×confidence)
MAX_OPEN_POSITIONS=5
DAILY_LOSS_LIMIT_PCT=0.03
CONFIDENCE_THRESHOLD=0.6
# Optional Phase 8 controls; unset keeps legacy behavior.
# MAX_DRAWDOWN_LIMIT_PCT=0.10
# MAX_EXPOSURE_PCT=0.80

# Scheduled Telegram reports. Hourly reports are intentionally not supported.
DAILY_REPORT_ENABLED=true
WEEKLY_REPORT_ENABLED=true
SUPERVISOR_RESTART_DELAY_SECONDS=5
